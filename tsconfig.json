// File for VSCode linter
{
  "compilerOptions": {
    "target": "ES2025",
    "module": "CommonJS",
    "lib": ["ES2025", "DOM"],
    "allowJs": true,
    "outDir": "./dist-tsc",
    "checkJs": true,
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/ts/types"
    ],
    "skipLibCheck": true,
    "rootDir": "./",
    "paths": {
      "": ["./src/"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "src/js/3rdparty/*"
  ]
}
